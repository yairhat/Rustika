<section id="horarios">
  <div class="container">
    <div class="horarios-grid">
      <div class="fade-up">
        <p class="section-label">Visítanos</p>
        <h2 class="section-title">Horarios</h2>
        <div class="divider"></div>
        <div class="open-badge">Abierto hoy</div>
        <table class="schedule-table">
          <tbody>
            <tr>
              <td>Lunes – Jueves</td>
