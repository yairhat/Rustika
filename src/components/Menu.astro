---
---

<section id="menu">
  <div class="container">
    <div class="fade-up">
      <p class="section-label">Lo que más nos piden</p>
      <h2 class="section-title">Menú</h2>
      <div class="divider"></div>
    </div>

    <div class="menu-tabs fade-up">
      <button class="menu-tab active" data-tab="pizzas">🍕 Pizzas</button>
      <button class="menu-tab" data-tab="pastas">🍝 Pastas</button>
      <button class="menu-tab" data-tab="burgers">🍔 Burgers</button>
      <button class="menu-tab" data-tab="bebidas">🍷 Bebidas</button>
    </div>

    <!-- PIZZAS -->
    <div id="tab-pizzas" class="menu-panel active">
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1574071318508-1cdbab80d002?w=700&q=80" alt="Pizza Margherita" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Clásica</p>
          <h3 class="menu-card-title">Margherita</h3>
          <p class="menu-card-desc">Tomate San Marzano, mozzarella de búfala, albahaca fresca. La pizza en su forma más pura.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=700&q=80" alt="Pizza Cuatro Quesos" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Favorita</p>
          <h3 class="menu-card-title">Cuatro Quesos</h3>
          <p class="menu-card-desc">Mozzarella, gouda ahumado, parmesano y gorgonzola. Para los que no pueden decidir.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1628840042765-356cda07504e?w=700&q=80" alt="Pizza Prosciutto" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Gourmet</p>
          <h3 class="menu-card-title">Prosciutto &amp; Rúcula</h3>
          <p class="menu-card-desc">Jamón serrano, rúcula fresca, tomate cherry y aceite de oliva extra virgen.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1534308983496-4fabb1a015ee?w=700&q=80" alt="Pizza Pepperoni" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Especial</p>
          <h3 class="menu-card-title">Pepperoni Especial</h3>
          <p class="menu-card-desc">Doble capa de pepperoni artesanal, mozzarella que se derrite y orégano del campo.</p>
        </div>
      </div>
    </div>

    <!-- PASTAS -->
    <div id="tab-pastas" class="menu-panel">
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1473093295043-cdd812d0e601?w=700&q=80" alt="Fetuccine Alfredo" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Clásica</p>
          <h3 class="menu-card-title">Fetuccine Alfredo</h3>
          <p class="menu-card-desc">Crema, mantequilla y parmesano en su punto. Sencilla, elegante, irresistible.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1622973536968-3ead9e780960?w=700&q=80" alt="Rigatoni Bolognesa" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Contundente</p>
          <h3 class="menu-card-title">Rigatoni Bolognesa</h3>
          <p class="menu-card-desc">Ragú de res y cerdo cocinado lento, con vino tinto y hierbas italianas. El comfort food definitivo.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1551183053-bf91798d792b?w=700&q=80" alt="Penne Arrabbiata" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Picante</p>
          <h3 class="menu-card-title">Penne Arrabbiata</h3>
          <p class="menu-card-desc">Salsa de tomate con ajo, chile, aceite de oliva y perejil. Para los que le entran al picante.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1595295333158-4742f28fbd85?w=700&q=80" alt="Linguine Aglio e Olio" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Ligera</p>
          <h3 class="menu-card-title">Linguine Aglio e Olio</h3>
          <p class="menu-card-desc">Ajo dorado, aceite de oliva, peperoncino y perejil. La receta más italiana de todas.</p>
        </div>
      </div>
    </div>

    <!-- BURGERS -->
    <div id="tab-burgers" class="menu-panel">
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=700&q=80" alt="BBQ Ribs Burger" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">La estrella</p>
          <h3 class="menu-card-title">BBQ Ribs Burger</h3>
          <p class="menu-card-desc">Carne jugosa, costilla ahumada, salsa BBQ y cebolla caramelizada. Para los que van en serio.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1571091718767-18b5b1457add?w=700&q=80" alt="Burger Italiana" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Fusión</p>
          <h3 class="menu-card-title">La Italiana</h3>
          <p class="menu-card-desc">Carne de res, mozzarella fundida, pesto, jitomate y rúcula. El sabor de Italia en cada mordida.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1553979459-d2229ba7433b?w=700&q=80" alt="Doble Smash" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Contundente</p>
          <h3 class="menu-card-title">Doble Smash</h3>
          <p class="menu-card-desc">Doble carne aplastada, queso americano, pepinillos y mostaza artesanal. Sin rodeos.</p>
        </div>
      </div>
    </div>

    <!-- BEBIDAS -->
    <div id="tab-bebidas" class="menu-panel">
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=700&q=80" alt="Selección de vinos" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Vinos</p>
          <h3 class="menu-card-title">Carta de Vinos</h3>
          <p class="menu-card-desc">Tintos y blancos nacionales e importados. Maridaje perfecto para tu pizza o pasta.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1556679343-c7306c1976bc?w=700&q=80" alt="Mojito" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Favorito de la casa</p>
          <h3 class="menu-card-title">Mojito Rústika</h3>
          <p class="menu-card-desc">Ron blanco, menta fresca, limón, azúcar y agua mineral. Ya es el pedido obligado.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=700&q=80" alt="Cócteles de temporada" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Temporada</p>
          <h3 class="menu-card-title">Cócteles del Chef</h3>
          <p class="menu-card-desc">Carta rotativa con recetas de temporada. Spritz, negroni, aperol y más. Pregunta al mesero.</p>
        </div>
      </div>
      <div class="menu-card">
        <img class="menu-card-img" src="https://images.unsplash.com/photo-1544145945-f90425340c7e?w=700&q=80" alt="Cervezas artesanales" loading="lazy">
        <div class="menu-card-body">
          <p class="menu-card-tag">Cervezas</p>
          <h3 class="menu-card-title">Cervezas Artesanales</h3>
          <p class="menu-card-desc">Selección de cervezas nacionales artesanales. Rubia, oscura o de trigo — la que mejor te acompañe.</p>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.menu-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.menu-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.menu-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      const tabId = (tab as HTMLElement).dataset.tab;
      document.getElementById('tab-' + tabId)?.classList.add('active');
    });
  });
</script>
