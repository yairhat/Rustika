          loading="lazy"
        >
      </div>
      <div class="gallery-item fade-up">
        <img
          src="https://images.unsplash.com/photo-1559329007-40df8a9345d8?w=600&q=80"
          alt="Horno de leña"
          loading="lazy"
        >
      </div>
      <div class="gallery-item fade-up">
        <img
          src="https://images.unsplash.com/photo-1546549032-9571cd6b27df?w=600&q=80"
